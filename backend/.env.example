# Configuracion del backend. Copiar a .env (NO commitear) o setear
# en el dashboard de Render.
#
# Para produccion en Render con disco persistente, las rutas deben
# apuntar a /var/data (configurado en render.yaml).

# json://<ruta-absoluta-o-relativa>
DATABASE_URL=json://data/db.json
# Render pone esta variable automaticamente
PORT=8000

# IMPORTANTE: cambiar en produccion. Render genera este valor
# automaticamente si usas render.yaml.
SECRET_KEY=dev-secret-change-me-in-prod

# CORS: lista separada por comas, o * para todos.
# En produccion, restringuir al dominio del frontend.
ALLOWED_ORIGINS=*

# Ruta del directorio de uploads. En Render: /var/data/uploads
UPLOAD_DIR=media/uploads
MAX_UPLOAD_MB=5
